# Example backend config. Copy to backend.hcl after running bootstrap.
# backend.hcl is generated by: ./scripts/bootstrap_terraform_backend.sh
# backend.hcl is in .gitignore (contains account-specific bucket name).

bucket         = "flights-terraform-state-ACCOUNT_ID"
key            = "terraform.tfstate"
region         = "us-east-1"
dynamodb_table = "terraform-state-lock"
