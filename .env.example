# Bright Data Google Flights Scraper (required)
BRIGHT_DATA_API_KEY=your_bright_data_api_key_here
BRIGHT_DATA_API_URL=https://api.brightdata.com/request

# Bronze bucket (optional; default matches Terraform dev: flights-bronze-raw-dev)
BRONZE_BUCKET=flights-bronze-raw-dev

# Request timeout in seconds (optional, default: 30)
REQUEST_TIMEOUT=30

# AWS credentials (optional; boto3 also uses ~/.aws/credentials)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Flight ingestion defaults for CLI (optional)
DEPARTURE_ID=LAX
ARRIVAL_ID=JFK
OUTBOUND_DATE=2026-04-15
